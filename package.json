{
  "name": "getmyseat",
  "version": "0.0.0",
  "private": true,
  "description": "GetMySeat monorepo: an interactive seating-map frontend and a user-data API backend.",
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --if-present run dev",
    "dev:frontend": "pnpm --filter frontend run dev",
    "dev:backend": "pnpm --filter backend run dev",
    "build": "pnpm -r --if-present run build",
    "test": "pnpm -r --if-present run test",
    "test:frontend": "pnpm --filter frontend run test",
    "test:backend": "pnpm --filter backend run test",
    "typecheck": "pnpm -r --if-present run typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
